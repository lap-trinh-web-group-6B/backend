<script>
    // Xử lý sự kiện mở đóng ngăn kéo menu sidebar trên mobile
    // (Note: Hỗ trợ responsive cho di động)
    document.addEventListener('DOMContentLoaded', () => {
        const drawer = document.getElementById('mobileDrawer');
        const sidebar = document.getElementById('drawerSidebar');
        const closeBtn = document.getElementById('closeDrawerBtn');
        const openBtn = document.getElementById('mobileMenuBtn'); // Nút này nằm trên Header

        function openDrawer() {
            drawer.classList.remove('hidden');
            // Cần một frame nhỏ để Tailwind render trước khi transform
            setTimeout(() => {
                sidebar.classList.remove('-translate-x-full');
            }, 10);
        }

        function closeDrawer() {
            sidebar.classList.add('-translate-x-full');
            setTimeout(() => {
                drawer.classList.add('hidden');
            }, 300); // 300ms theo đúng duration của transition Tailwind
        }

        if (openBtn) openBtn.addEventListener('click', openDrawer);
        if (closeBtn) closeBtn.addEventListener('click', closeDrawer);

        // Nhấn ra ngoài để đóng bg overlay
        if (drawer) {
            drawer.addEventListener('click', (e) => {
                if (e.target === drawer) closeDrawer();
            });
        }
    });
</script>