<!-- Header Navbar -->
<!-- (Note: Thanh header ngang hiển thị thông tin account đang login và nút đăng xuất) -->
<header class="bg-white shadow-sm z-10 sticky top-0 md:relative">
    <div class="flex items-center justify-between px-6 py-4">

        <!-- Mobile menu hamburger -->
        <!-- (Note: Thiết bị hẹp sẽ hiển thị icon Hamburger, gọi tới hàm sidebarDrawerJS) -->
        <div class="flex items-center md:hidden">
            <button id="mobileMenuBtn" class="text-gray-500 hover:text-gray-700 focus:outline-none focus:text-gray-700">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
            <h1 class="ml-4 text-xl font-semibold text-gray-800 uppercase truncate">
                <!-- Tùy thuộc title của trang được truyền sang -->
                <%= typeof pageTitle !=='undefined' ? pageTitle : 'Bảng Điều Khiển' %>
            </h1>
        </div>

        <!-- Tiêu đề trên màn hình lớn -->
        <div class="hidden md:block">
            <h2 class="text-xl font-semibold text-gray-800">
                <%= typeof pageTitle !=='undefined' ? pageTitle : 'Bảng Điều Khiển' %>
            </h2>
        </div>

        <!-- Avatar, tên ng dùng, logout -->
        <div class="flex items-center space-x-4">
            <div class="hidden sm:flex flex-col items-end">
                <!-- Tên admin lấy từ biến req.admin.username thông qua controller -->
                <!-- (Note: Hiển thị tên tài khoản) -->
                <span class="text-sm font-semibold text-gray-700">Xin chào, <%= typeof adminUsername !=='undefined' ?
                        adminUsername : 'Admin' %></span>
                <span class="text-xs text-primary font-bold">Administrator</span>
            </div>

            <div class="h-10 w-10 overflow-hidden rounded-full border-2 border-primary mr-2">
                <img src="https://ui-avatars.com/api/?name=Admin+Monety&background=00BBA7&color=fff" alt="Avatar"
                    class="h-full w-full object-cover">
            </div>

            <!-- Nút đăng xuất -->
            <!-- (Note: Gọi submit Form POST /admin/logout trực tiếp) -->
            <form action="/admin/logout" method="POST" class="inline">
                <button type="submit"
                    class="text-gray-500 hover:text-red-600 transition-colors p-2 rounded hover:bg-red-50"
                    title="Đăng xuất">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1">
                        </path>
                    </svg>
                </button>
            </form>
        </div>
    </div>
</header>