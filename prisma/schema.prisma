generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model budgets {
  id                 Int                         @id @default(autoincrement())
  user_id            Int
  category_id        Int
  amount_limit       Decimal                     @db.Decimal(18, 2)
  start_date         DateTime                    @db.Timestamp(6)
  end_date           DateTime                    @db.Timestamp(6)
  status             budgets_status_enum         @default(ACTIVE)
  final_spent_amount Decimal?                    @db.Decimal(18, 2)
  result_status      budgets_result_status_enum?
  is_alert_enabled   Boolean                     @default(true)
  alert_threshold    Decimal                     @default(0.8) @db.Decimal(3, 2)
  completion_date    DateTime?                   @db.Timestamp(6)
  createdAt          DateTime                    @default(now()) @db.Timestamp(6)
  updatedAt          DateTime                    @default(now()) @db.Timestamp(6)
  categories         categories                  @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users                       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model categories {
  id              Int                    @id @default(autoincrement())
  user_id         Int?
  name            String                 @db.VarChar
  name_normalized String                 @db.VarChar
  type            categories_type_enum   @default(EXPENSE)
  icon_url        String?                @db.VarChar
  status          categories_status_enum @default(ACTIVATE)
  createdAt       DateTime               @default(now()) @db.Timestamp(6)
  budgets         budgets[]
  users           users?                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions    transactions[]
}

model notifications {
  id         Int                       @id @default(autoincrement())
  user_id    Int
  title      String                    @db.VarChar
  message    String
  type       notifications_type_enum
  is_read    Boolean                   @default(false)
  status     notifications_status_enum @default(ACTIVE)
  created_at DateTime                  @default(now()) @db.Timestamp(6)
  deleted_at DateTime?                 @db.Timestamp(6)
  users      users                     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at])
  @@index([user_id])
}

model orders {
  id        Int                @id @default(autoincrement())
  userId    Int
  orderCode String             @db.VarChar(8)
  amount    Int
  status    orders_status_enum @default(pending)
  createdAt DateTime           @default(now()) @db.Timestamp(6)
  users     users              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model otps {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar
  otp       String   @db.VarChar(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)
}

model transactions {
  id                Int                      @id @default(autoincrement())
  user_id           Int
  wallet_id         Int
  category_id       Int
  note              String?
  amount            Decimal                  @default(0) @db.Decimal(18, 2)
  currency          String                   @default("VND") @db.VarChar
  source            transactions_source_enum @default(MANUAL)
  receipt_image_url String?                  @db.VarChar
  status            transactions_status_enum @default(ACTIVATE)
  transaction_date  DateTime                 @db.Timestamp(6)
  createdAt         DateTime                 @default(now()) @db.Timestamp(6)
  wallets           wallets                  @relation(fields: [wallet_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_0b171330be0cb621f8d73b87a9e")
  categories        categories               @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_c9e41213ca42d50132ed7ab2b0f")
  users             users                    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_e9acc6efa76de013e8c1553ed2b")
}

model users {
  id            Int               @id @default(autoincrement())
  email         String            @db.VarChar
  password      String            @db.VarChar
  syncId        String?           @db.VarChar
  avatar        String?           @db.VarChar
  fullName      String            @db.VarChar
  fcmToken      String?           @db.VarChar
  type          users_type_enum   @default(FREE)
  status        users_status_enum @default(ACTIVATE)
  createdAt     DateTime          @default(now()) @db.Timestamp(6)
  budgets       budgets[]
  categories    categories[]
  notifications notifications[]
  orders        orders[]
  transactions  transactions[]
  wallets       wallets[]
}

model wallets {
  id           Int                 @id @default(autoincrement())
  user_id      Int
  name         String              @db.VarChar
  balance      Decimal             @default(0) @db.Decimal(18, 2)
  currency     String              @default("VND") @db.VarChar
  type         wallets_type_enum
  status       wallets_status_enum @default(ACTIVATE)
  createdAt    DateTime            @default(now()) @db.Timestamp(6)
  transactions transactions[]
  users        users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_92558c08091598f7a4439586cda")

  @@unique([user_id, name])
}

enum budgets_result_status_enum {
  UNDER_BUDGET
  EXACT
  OVER_BUDGET
}

enum budgets_status_enum {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum categories_status_enum {
  ACTIVATE
  DISABLED
}

enum categories_type_enum {
  INCOME
  EXPENSE
}

enum notifications_status_enum {
  ACTIVE
  DELETED
}

enum notifications_type_enum {
  WARNING
  REMINDER
  SYSTEM
}

enum orders_status_enum {
  pending
  success
  failed
}

enum transactions_source_enum {
  MANUAL
  OCR_SCAN
}

enum transactions_status_enum {
  ACTIVATE
  DISABLED
}

enum users_status_enum {
  ACTIVATE
  DISABLE
  BANNED
  CANCEL
}

enum users_type_enum {
  FREE
  PREMIUM
}

enum wallets_status_enum {
  ACTIVATE
  DISABLED
}

enum wallets_type_enum {
  CASH
  BANK_ACCOUNT
  E_WALLET
}
